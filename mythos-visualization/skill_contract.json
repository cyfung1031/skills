    "modules/02_evidence_claims.md",
    "modules/03_domain_lenses.md",
    "modules/04_corpus_batch.md",
    "modules/05_source_render_runtime.md",
    "modules/06_output_contracts.md",
    "modules/07_release_review.md"
  ],
  "scripts": [
    "scripts/mythos_state_check.py",
    "scripts/mythos_corpus_probe.py",
    "scripts/mythos_report_lint.py"
  ],
  "release_gate": {
